# ============================================================
# CareSync AI - Environment Variables Template
# ============================================================
# NEVER commit your real .env file to git!
# Copy this file to .env and fill in your real keys.

# --- Server Config ---
PORT=5000
NODE_ENV=development

# --- Google Gemini API (Vision AI Agent) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI (Fallback LLM for Analyst & Decision Agents) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Resend Email API (MCP Tool: send_email_alert) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@caresync-ai.com

# --- Fallback: Nodemailer SMTP (if Resend is unavailable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# --- LangChain Tracing (Optional, for debugging agent chains) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=caresync-ai-hackathon
